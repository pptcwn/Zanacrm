# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing and coverage
/coverage/

# next.js
/.next/
/out/

# production builds
/build/

# local caches and temporary files
/.npm-cache/
/.npm-tmp/
/.pnpm-store/
/.cache/
/.turbo/
/F;*/

# env files
.env
.env.*
!.env.example

# Supabase local state
/supabase/.temp/

# local editor and automation tooling
/.agent/
/.agents/
/.codex/
/.kilo/
/.superpowers/
/.vscode/
/.mcp.json
/mcps/
/antigravity-auto-accept/
/pnpm-workspace.yaml

# local ad-hoc UI scripts
/test_ui.js
/test_ui.py

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# misc
.DS_Store
Thumbs.db
*.pem

# vercel
.vercel/

# typescript
*.tsbuildinfo
next-env.d.ts
